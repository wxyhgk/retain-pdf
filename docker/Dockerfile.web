FROM nginx:1.27-alpine

RUN apk add --no-cache bash gettext

COPY frontend/ /usr/share/nginx/html/
COPY docker/nginx.conf.template /etc/nginx/templates/default.conf.template
COPY docker/entrypoint-web.sh /docker-entrypoint.d/99-runtime-config.sh

RUN rm -rf \
  /usr/share/nginx/html/node_modules \
  /usr/share/nginx/html/.ipynb_checkpoints \
  /usr/share/nginx/html/src/.ipynb_checkpoints && \
  rm -f \
  /usr/share/nginx/html/runtime-config.local.js \
  /usr/share/nginx/html/package.json \
  /usr/share/nginx/html/package-lock.json \
  /usr/share/nginx/html/tailwind.config.js \
  /usr/share/nginx/html/.gitignore

RUN chmod +x /docker-entrypoint.d/99-runtime-config.sh

EXPOSE 80
