# Docker 公共版前端运行时配置
# FRONT_API_BASE 通常留空，前端会自动走同源代理。
# 普通用户不需要在页面里看到或填写 API Base。
FRONT_API_BASE=

# 这里必须和 docker/auth.local.json 里的某一个后端 key 保持一致。
# 前端会自动带上这个后端鉴权 key。
FRONT_X_API_KEY=replace-with-your-backend-key

# 可选的下游默认配置。
# 如果希望最终用户在浏览器里自己填写 MinerU / 模型配置，就保持为空。
FRONT_MINERU_TOKEN=
FRONT_MODEL_API_KEY=
FRONT_MODEL=deepseek-chat
FRONT_BASE_URL=https://api.deepseek.com/v1

# Docker 公共版前端当前只暴露 DeepSeek 这个 provider 预设。
FRONT_PROVIDER_PRESET=deepseek
